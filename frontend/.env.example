# Base URL for the backend API.
# Leave as-is to use the Vite dev proxy (recommended for local dev), or point
# it directly at the backend, e.g. http://localhost:4000/api
VITE_API_BASE_URL=/api

# Socket.IO server origin. Leave blank to connect same-origin via the dev proxy.
# For a split deployment, set the backend origin, e.g. https://api.example.com
VITE_SOCKET_URL=
