# ---- Server ----
PORT=4000
NODE_ENV=development

# ---- Database ----
# Provide a real MongoDB connection string (Atlas or local) for persistence.
# If left blank, the server boots an in-memory MongoDB (mongodb-memory-server)
# so you can run the project with ZERO MongoDB setup. Data is NOT persisted
# across restarts in that mode.
MONGODB_URI=

# ---- Auth ----
# Change this to a long random string in any real deployment.
JWT_SECRET=super-secret-change-me-in-production
JWT_EXPIRES_IN=7d

# ---- Booking rules ----
# How long a reservation is held before it expires (minutes).
RESERVATION_TTL_MINUTES=10

# Seed demo data on boot if the DB is empty (useful with a real MONGODB_URI in
# Docker/demo). The in-memory DB always auto-seeds regardless of this flag.
SEED_ON_START=false

# ---- CORS ----
# Comma-separated list of allowed origins for the frontend.
CLIENT_ORIGIN=http://localhost:5173
